# Exa AI (server only) — required for live AI analysis & research
EXA_API_KEY=

# Supabase Postgres — REQUIRED for multi-laptop sync (same keys on every machine).
# Setup UI: /admin/database  |  SQL: supabase/migrations/001_urbanexus.sql
# New keys: sb_publishable_… (anon) + sb_secret_… (service). Legacy JWT keys also work.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias for the publishable key:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias for the secret key:
# SUPABASE_SECRET_KEY=

# Optional: required on Vercel to call POST /api/db/seed
DB_SEED_SECRET=
