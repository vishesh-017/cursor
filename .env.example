# Exa AI (server only) — required for live AI analysis & research
EXA_API_KEY=

# Supabase Postgres (optional). When all three are set, reports/users persist in DB.
# Without them the app uses in-memory seed data (fine for local demo).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: required on Vercel to call POST /api/db/seed
DB_SEED_SECRET=
